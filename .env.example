APP_ENV=local
APP_KEY=

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dms_db_${MAYA_SLOT_DB}
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── Conexión a la BD (gestionada por infra/) ─────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432

# ─── FDW: catálogo users + teams (origen: Odoo v_app_users / v_dms_*) ─
# Por defecto apunta a la BD `odoo` del propio Postgres compartido. En
# staging/prod sobreescribir con el host real del backend Odoo.
FDW_USERS_HOST=maya_infra_postgres
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=odoo
FDW_USERS_USERNAME=maya
FDW_USERS_PASSWORD=secret
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=v_app_users
FDW_USERS_CACHE_TTL=900

FDW_TEAMS_HOST=maya_infra_postgres
FDW_TEAMS_PORT=5432
FDW_TEAMS_DATABASE=odoo
FDW_TEAMS_USERNAME=maya
FDW_TEAMS_PASSWORD=secret
FDW_TEAMS_SCHEMA=public
FDW_TEAMS_TABLE=v_dms_teams

FDW_TEAM_MEMBERS_HOST=maya_infra_postgres
FDW_TEAM_MEMBERS_PORT=5432
FDW_TEAM_MEMBERS_DATABASE=odoo
FDW_TEAM_MEMBERS_USERNAME=maya
FDW_TEAM_MEMBERS_PASSWORD=secret
FDW_TEAM_MEMBERS_SCHEMA=public
FDW_TEAM_MEMBERS_TABLE=v_dms_team_members

# ─── FDW: permisos resueltos del usuario (origen maya_authorization) ─
# En local, dms lee la vista `v_dms_user_permissions` proyectada por
# maya_authorization en la misma instancia Postgres compartida. En
# staging/prod sobreescribir host/credentials con el backend remoto real.
FDW_USER_PERMISSIONS_HOST=maya_infra_postgres
FDW_USER_PERMISSIONS_PORT=5432
FDW_USER_PERMISSIONS_DATABASE=maya_auth_${MAYA_SLOT_DB}
FDW_USER_PERMISSIONS_USERNAME=maya
FDW_USER_PERMISSIONS_PASSWORD=secret
FDW_USER_PERMISSIONS_SCHEMA=public
FDW_USER_PERMISSIONS_REMOTE_VIEW=v_dms_user_permissions

# ─── Redis (gestionado por infra/) ───────────────────────────
REDIS_PASSWORD=secret

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/${MAYA_SLOT}/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms,maya-dashboard,maya-authorization,maya-audit,maya-logs
JWT_ISSUER=https://keycloak.${DOMAIN_SUFFIX}/realms/${MAYA_SLOT}

# Control de seeders al arrancar (up.sh): always | if-empty | never
DB_SEED_MODE=if-empty

# ─── Caché / Redis (gestionada por infra/) ────────────────────
CACHE_STORE=redis
REDIS_HOST=maya_redis
REDIS_PORT=6379

# ─── RabbitMQ (gestionado por infra/) ─────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/${MAYA_SLOT_DB}
QUEUE_CONNECTION=rabbitmq

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=              # generar: php artisan reverb:install
REVERB_APP_SECRET=           # generar: php artisan reverb:install
REVERB_HOST=0.0.0.0
REVERB_PORT=8082
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_REGEX_DOMAIN=${DOMAIN_SUFFIX}
CORS_ADDITIONAL_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5476,http://localhost:5477

# ─── Frontend (VITE_*) ────────────────────────────────────────
# Usar hostnames Traefik (*.localhost), NO nombres de servicio Docker
VITE_API_URL=https://${HOST_PREFIX}dms-api.${DOMAIN_SUFFIX}/api/v1
VITE_KEYCLOAK_URL=https://keycloak.${DOMAIN_SUFFIX}
VITE_KEYCLOAK_REALM=${MAYA_SLOT}
VITE_KEYCLOAK_CLIENT_ID=maya-dms
VITE_DASHBOARD_API_URL=https://${HOST_PREFIX}dashboard-api.${DOMAIN_SUFFIX}
VITE_REVERB_APP_KEY=         # mismo valor que REVERB_APP_KEY
VITE_REVERB_HOST=dms-api.${DOMAIN_SUFFIX}
VITE_REVERB_PORT=8082

# ─── Puertos host ──────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=5574

# ─── Permisos Docker bind mounts (opcional) ────────────────────
# Si no se definen, up.sh calcula LOCAL_UID/LOCAL_GID automáticamente.
LOCAL_UID=
LOCAL_GID=
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}
HOST_PREFIX=${HOST_PREFIX}
DOMAIN_SUFFIX=${DOMAIN_SUFFIX}
