APP_ENV=local
APP_KEY=

# ─── Base de datos propia ─────────────────────────────────────
DB_HOST=postgres
DB_PORT=5433
DB_DATABASE=maya_dms_db
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── FDW: tabla users (origen: Keycloak / dashboard corporativo) ─
# En local: no se usan — las migraciones crean tablas stub locales.
# En producción: obligatorias para conectar con postgres_fdw.
FDW_USERS_HOST=host-del-servicio-origen
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=main_db
FDW_USERS_USERNAME=readonly_maya_dms
FDW_USERS_PASSWORD=
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=users

# ─── Redis ───────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PASSWORD=secret
REDIS_PORT=6380

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://keycloak:8080/realms/maya/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms-backend
JWT_ISSUER=http://keycloak.localhost/realms/maya

# ─── RabbitMQ ─────────────────────────────────────────────────
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/
QUEUE_CONNECTION=rabbitmq

# Puertos host (evita conflicto con maya_authorization opcional que usa 5672/15672)
RABBITMQ_HOST_PORT=5673
RABBITMQ_MGMT_PORT=15673

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=              # generar: php artisan reverb:install
REVERB_APP_SECRET=           # generar: php artisan reverb:install
REVERB_HOST=0.0.0.0
REVERB_PORT=8082
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://maya-dms.localhost,http://localhost:5174

# ─── Frontend (VITE_*) ────────────────────────────────────────
# Usar hostnames Traefik (*.localhost), NO nombres de servicio Docker
VITE_API_URL=http://maya-dms-api.localhost/api/v1
VITE_KEYCLOAK_URL=http://keycloak.localhost
VITE_KEYCLOAK_REALM=maya
VITE_KEYCLOAK_CLIENT_ID=maya-dms-dashboard
VITE_REVERB_APP_KEY=         # mismo valor que REVERB_APP_KEY
VITE_REVERB_HOST=maya-dms-api.localhost
VITE_REVERB_PORT=8082

# ─── Puertos host (colisión con otras apps del ecosistema) ─────
# maya_authorization: 8000 / 5173 / 5432 / rabbitmq 5672,15672
# maya-dms:          8001 / 5174 / 5433 / rabbitmq 5673,15673
BACKEND_PORT=8001
FRONTEND_PORT=5174
DB_HOST_PORT=5433
