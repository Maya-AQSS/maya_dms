APP_ENV=local
APP_KEY=

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_DATABASE=maya_dms_db_${MAYA_SLOT_DB}
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── FDW: tabla users (origen: Keycloak / dashboard corporativo) ─
# En local: no se usan — las migraciones crean tablas stub locales.
# En producción: obligatorias para conectar con postgres_fdw.
FDW_USERS_HOST=host-del-servicio-origen
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=main_db
FDW_USERS_USERNAME=readonly_maya_dms
FDW_USERS_PASSWORD=
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=users
FDW_USERS_CACHE_TTL=900

# ─── FDW: asignaciones usuario ↔ permiso (origen corporativo) ─
FDW_USER_PERMISSIONS_HOST=host-del-servicio-origen
FDW_USER_PERMISSIONS_PORT=5432
FDW_USER_PERMISSIONS_DATABASE=main_db
FDW_USER_PERMISSIONS_USERNAME=readonly_maya_dms
FDW_USER_PERMISSIONS_PASSWORD=
FDW_USER_PERMISSIONS_SCHEMA=public
FDW_USER_PERMISSIONS_TABLE=user_permissions

# ─── Redis (gestionado por infra/) ───────────────────────────
REDIS_PASSWORD=secret

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/${MAYA_SLOT}/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms
JWT_ISSUER=https://keycloak.${DOMAIN_SUFFIX}/realms/${MAYA_SLOT}

# Control de seeders al arrancar (up.sh): always | if-empty | never
DB_SEED_MODE=if-empty

# ─── RabbitMQ (gestionado por infra/) ─────────────────────────
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/${MAYA_SLOT_DB}
QUEUE_CONNECTION=rabbitmq

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=              # generar: php artisan reverb:install
REVERB_APP_SECRET=           # generar: php artisan reverb:install
REVERB_HOST=0.0.0.0
REVERB_PORT=8082
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_REGEX_DOMAIN=${DOMAIN_SUFFIX}
CORS_ADDITIONAL_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5476,http://localhost:5477

# ─── Frontend (VITE_*) ────────────────────────────────────────
# Usar hostnames Traefik (*.localhost), NO nombres de servicio Docker
VITE_API_URL=https://${HOST_PREFIX}dms-api.${DOMAIN_SUFFIX}/api/v1
VITE_KEYCLOAK_URL=https://keycloak.${DOMAIN_SUFFIX}
VITE_KEYCLOAK_REALM=${MAYA_SLOT}
VITE_KEYCLOAK_CLIENT_ID=maya-dms
VITE_REVERB_APP_KEY=         # mismo valor que REVERB_APP_KEY
VITE_REVERB_HOST=dms-api.${DOMAIN_SUFFIX}
VITE_REVERB_PORT=8082

# ─── Puertos host ──────────────────────────────────────────────
BACKEND_PORT=8001
FRONTEND_PORT=5474

# ─── Permisos Docker bind mounts (opcional) ────────────────────
# Si no se definen, up.sh calcula LOCAL_UID/LOCAL_GID automáticamente.
LOCAL_UID=
LOCAL_GID=
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}
HOST_PREFIX=${HOST_PREFIX}
DOMAIN_SUFFIX=${DOMAIN_SUFFIX}
