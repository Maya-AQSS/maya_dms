FROM node:24-alpine

# git required by npm to clone github: URLs (e.g. @maya/shared-*-react)
RUN apk add --no-cache git
WORKDIR /app
COPY package*.json ./
RUN npm install
COPY . .
EXPOSE 5173
# Entrypoint runs npm install if needed, then starts Vite
COPY --chmod=755 docker-entrypoint.sh /usr/local/bin/docker-entrypoint.sh
ENTRYPOINT ["docker-entrypoint.sh"]
