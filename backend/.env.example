APP_NAME="Maya DMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://maya_dms_api.localhost

# Tests automatizados: usar `make test` (desde maya_dms/) o `env APP_ENV=testing DB_CONNECTION=sqlite DB_DATABASE=:memory: DB_URL= php artisan test`
# en backend; no ejecutar la suite contra la misma Postgres que el navegador (RefreshDatabase hace migrate:fresh).

LOG_CHANNEL=stack
LOG_STACK=daily,rabbit
LOG_LEVEL=debug
LOG_RABBIT_LEVEL=warning
MAYA_MESSAGING_APP=maya_dms

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432
DB_DATABASE=maya_dms_db
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── Redis (gestionado por infra/) ───────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=maya_redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=1

# ─── FDW: tabla users (origen: dashboard corporativo) ────────
# En local: no se usan — las migraciones crean tablas stub locales.
# En producción: obligatorias para conectar con postgres_fdw.
FDW_USERS_HOST=host-del-servicio-origen
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=main_db
FDW_USERS_USERNAME=readonly_maya_dms
FDW_USERS_PASSWORD=
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=users
FDW_USERS_CACHE_TTL=900

# ─── FDW: asignaciones usuario ↔ permiso (origen corporativo) ─
# En local: la migración usa `user_permissions_source` en esta misma BD.
# En producción: tabla remota expuesta vía postgres_fdw.
FDW_USER_PERMISSIONS_HOST=host-del-servicio-origen
FDW_USER_PERMISSIONS_PORT=5432
FDW_USER_PERMISSIONS_DATABASE=main_db
FDW_USER_PERMISSIONS_USERNAME=readonly_maya_dms
FDW_USER_PERMISSIONS_PASSWORD=
FDW_USER_PERMISSIONS_SCHEMA=public
FDW_USER_PERMISSIONS_TABLE=user_permissions

# ─── Cache / Queue / Session ─────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/maya/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms
JWT_ISSUER=http://keycloak.localhost/realms/maya

# Solo APP_ENV=local: si es true, JwtMiddleware omite el Bearer y fija un usuario de desarrollo.
# Nunca activar en staging o producción (anula permisos reales y claims).
# DEV_BYPASS_AUTH=false

# Realm roles que pueden gestionar el catálogo de equipos y miembros (coma-separados).
# TEAM_MANAGEMENT_ROLES sustituye a GROUP_MANAGEMENT_ROLES (se mantiene como respaldo en config).
TEAM_MANAGEMENT_ROLES=manager,super-admin,admin

# Claims JWT opcionales (mappers en Keycloak) para visibilidad por jerarquía académica:
# study_type_id o study_type_ids[], study_id o study_ids[],
# module_id o module_ids[] (o course_module_id / course_module_ids[]).

# ─── RabbitMQ (gestionado por infra/) ─────────────────────────
RABBITMQ_HOST=maya_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8082
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://maya_dms.localhost,http://localhost:5174

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log
