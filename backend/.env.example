APP_NAME="Maya DMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://maya-dms-api.localhost

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432
DB_DATABASE=maya_dms_db
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── Redis (gestionado por infra/) ───────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=maya_redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=1

# ─── FDW: tabla users (origen: dashboard corporativo) ────────
# En local: no se usan — las migraciones crean tablas stub locales.
# En producción: obligatorias para conectar con postgres_fdw.
FDW_USERS_HOST=host-del-servicio-origen
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=main_db
FDW_USERS_USERNAME=readonly_maya_dms
FDW_USERS_PASSWORD=
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=users
FDW_USERS_CACHE_TTL=900

# ─── Cache / Queue / Session ─────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/maya/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms-backend
JWT_ISSUER=http://keycloak.localhost/realms/maya

# Realm roles que pueden crear/editar/eliminar grupos y miembros (coma-separados)
GROUP_MANAGEMENT_ROLES=manager,super-admin,admin

# Realm roles que pueden definir plantillas con visibilidad compartida (no solo personal):
# p. ej. Jefe de Departamento, Jefe de Estudios, Dirección — deben coincidir con Keycloak
TEMPLATE_SHARED_VISIBILITY_ROLES=department-head,studies-head,director

# ─── RabbitMQ (gestionado por infra/) ─────────────────────────
RABBITMQ_HOST=maya_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/

# ─── Laravel Reverb (WebSocket) ───────────────────────────────
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=0.0.0.0
REVERB_PORT=8082
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://maya-dms.localhost,http://localhost:5174

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log
