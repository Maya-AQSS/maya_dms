APP_NAME="Maya DMS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://${HOST_PREFIX}dms-api.${DOMAIN_SUFFIX}

# Tests automatizados: usar `make test` (desde maya_dms/) o `env APP_ENV=testing DB_CONNECTION=sqlite DB_DATABASE=:memory: DB_URL= php artisan test`
# en backend; no ejecutar la suite contra la misma Postgres que el navegador (RefreshDatabase hace migrate:fresh).

LOG_CHANNEL=stack
LOG_STACK=daily,rabbit
LOG_LEVEL=debug
LOG_RABBIT_LEVEL=warning
MAYA_MESSAGING_APP=maya-dms

# ─── Base de datos (gestionada por infra/) ────────────────────
DB_CONNECTION=pgsql
DB_HOST=maya_infra_postgres
DB_PORT=5432
DB_DATABASE=maya_dms_db_${MAYA_SLOT_DB}
DB_USERNAME=maya_dms_user
DB_PASSWORD=secret

# ─── Redis (gestionado por infra/) ───────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=maya_redis
REDIS_PASSWORD=secret
REDIS_PORT=6379
REDIS_DB=${REDIS_DB_INDEX}

# ─── FDW: tabla users (origen Odoo v_app_users vía postgres_fdw) ─
# En local apunta a la BD `odoo` del Postgres compartido (mismo cluster).
# En staging/prod sobreescribir con el host real del backend Odoo.
FDW_USERS_HOST=maya_infra_postgres
FDW_USERS_PORT=5432
FDW_USERS_DATABASE=odoo
FDW_USERS_USERNAME=maya
FDW_USERS_PASSWORD=secret
FDW_USERS_SCHEMA=public
FDW_USERS_TABLE=v_app_users
FDW_USERS_CACHE_TTL=900

# ─── FDW: user_resolved_permissions (federada con maya_authorization) ─
# Vista canónica de permisos resueltos. En local apunta a la BD maya_auth
# vía postgres_fdw. Los defaults en config/database.php ya apuntan a
# maya_infra_postgres / maya_auth / maya / secret y al remote_view
# `v_dms_user_permissions`. Solo sobreescribir para staging/prod.
# FDW_USER_PERMISSIONS_HOST=maya_infra_postgres
# FDW_USER_PERMISSIONS_PORT=5432
# FDW_USER_PERMISSIONS_DATABASE=maya_auth
# FDW_USER_PERMISSIONS_USERNAME=maya
# FDW_USER_PERMISSIONS_PASSWORD=secret
# FDW_USER_PERMISSIONS_SCHEMA=public
# FDW_USER_PERMISSIONS_REMOTE_VIEW=v_portal_user_permissions

# ─── Cache / Queue / Session ─────────────────────────────────
CACHE_STORE=redis
QUEUE_CONNECTION=rabbitmq
SESSION_DRIVER=redis
SESSION_LIFETIME=120

# ─── JWT / JWKS (Keycloak) ────────────────────────────────────
JWKS_URL=http://maya_auth_keycloak:8080/realms/${MAYA_SLOT}/protocol/openid-connect/certs
JWT_AUDIENCE=maya-dms
JWT_ISSUER=https://keycloak.${DOMAIN_SUFFIX}/realms/${MAYA_SLOT}
JWKS_CACHE_TTL=3600

# Solo APP_ENV=local: si es true, JwtMiddleware omite el Bearer y fija un usuario de desarrollo.
# Nunca activar en staging o producción (anula permisos reales y claims).
# DEV_BYPASS_AUTH=false

# Realm roles que pueden gestionar el catálogo de equipos y miembros (coma-separados).
# TEAM_MANAGEMENT_ROLES sustituye a GROUP_MANAGEMENT_ROLES (se mantiene como respaldo en config).
TEAM_MANAGEMENT_ROLES=manager,super-admin,admin

# Claims JWT opcionales (mappers en Keycloak) para visibilidad por jerarquía académica:
# study_type_id o study_type_ids[], study_id o study_ids[],
# module_id o module_ids[] (o course_module_id / course_module_ids[]).

# ─── RabbitMQ (gestionado por infra/) ─────────────────────────
RABBITMQ_HOST=maya_rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin
RABBITMQ_VHOST=/${MAYA_SLOT_DB}

# ─── Laravel Reverb (WebSocket — notificaciones en tiempo real) ──────
# REVERB_HOST: hostname expuesto al navegador (vía Traefik). En local apunta a
# dms-reverb.${DOMAIN_SUFFIX}. El servidor Reverb escucha en 0.0.0.0:8080
# dentro del contenedor — REVERB_SERVER_HOST/PORT controlan el bind interno.
REVERB_APP_ID=maya-dms
REVERB_APP_KEY=maya-dms-key-change-me
REVERB_APP_SECRET=maya-dms-secret-change-me
REVERB_HOST=${HOST_PREFIX}dms-reverb.${DOMAIN_SUFFIX}
REVERB_PORT=443
REVERB_SCHEME=https
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=8080
BROADCAST_CONNECTION=reverb

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=https://${HOST_PREFIX}dms.${DOMAIN_SUFFIX},http://localhost:5174

# ─── Mail ─────────────────────────────────────────────────────
MAIL_MAILER=log

# ─── Slot context (materializadas por envsubst en up-common.sh) ───────────────
MAYA_SLOT=${MAYA_SLOT}
MAYA_SLOT_DB=${MAYA_SLOT_DB}
HOST_PREFIX=${HOST_PREFIX}
DOMAIN_SUFFIX=${DOMAIN_SUFFIX}
